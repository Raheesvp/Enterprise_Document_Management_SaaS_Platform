{"lines":["using System.IdentityModel.Tokens.Jwt;\r","using System.Security.Claims;\r","using System.Security.Cryptography;\r","using System.Text;\r","using IdentityService.Application.Interfaces;\r","using IdentityService.Domain.Entities;\r","using Microsoft.Extensions.Configuration;\r","using Microsoft.IdentityModel.Tokens;\r","\r","namespace IdentityService.Infrastructure.Services;\r","\r","// JwtService — generates JWT access tokens with tenant + role claims\r","// This is the core of the SSO pattern the senior built at AUB\r","//\r","// Token contains:\r","// → sub (userId)\r","// → email\r","// → tenant_id ← Gateway extracts this and forwards as header\r","// → role ← Used for RBAC authorization\r","// → jti (unique token ID — for token revocation tracking)\r","public sealed class JwtService : IJwtService\r","{\r","    private readonly IConfiguration _configuration;\r","\r","    public JwtService(IConfiguration configuration)\r","        => _configuration = configuration;\r","\r","    public string GenerateAccessToken(User user, Tenant tenant)\r","    {\r","        var jwtSettings = _configuration.GetSection(\"JwtSettings\");\r","        var secretKey = jwtSettings[\"SecretKey\"]!;\r","        var issuer = jwtSettings[\"Issuer\"]!;\r","        var audience = jwtSettings[\"Audience\"]!;\r","        var expiryMinutes = int.Parse(jwtSettings[\"ExpiryMinutes\"] ?? \"60\");\r","\r","        var key = new SymmetricSecurityKey(Encoding.UTF8.GetBytes(secretKey));\r","        var credentials = new SigningCredentials(key, SecurityAlgorithms.HmacSha256);\r","\r","        // Claims embedded in JWT — readable by gateway and all services\r","        var claims = new[]\r","        {\r","            new Claim(JwtRegisteredClaimNames.Sub, user.Id.ToString()),\r","            new Claim(JwtRegisteredClaimNames.Email, user.Email),\r","            new Claim(JwtRegisteredClaimNames.Jti, Guid.NewGuid().ToString()),\r","            new Claim(JwtRegisteredClaimNames.Iat,\r","                DateTimeOffset.UtcNow.ToUnixTimeSeconds().ToString()),\r","            new Claim(\"tenant_id\", tenant.Id.ToString()),\r","            new Claim(\"tenant_name\", tenant.Name),\r","            new Claim(\"tenant_subdomain\", tenant.Subdomain),\r","            new Claim(ClaimTypes.Role, user.Role.ToString()),\r","            new Claim(\"full_name\", user.FullName)\r","        };\r","\r","        var token = new JwtSecurityToken(\r","            issuer: issuer,\r","            audience: audience,\r","            claims: claims,\r","            expires: GetAccessTokenExpiry(),\r","            signingCredentials: credentials);\r","\r","        return new JwtSecurityTokenHandler().WriteToken(token);\r","    }\r","\r","    // Cryptographically secure random token — not JWT\r","    // Stored in DB, opaque to client\r","    public string GenerateRefreshToken()\r","    {\r","        var randomBytes = new byte[64];\r","        using var rng = RandomNumberGenerator.Create();\r","        rng.GetBytes(randomBytes);\r","        return Convert.ToBase64String(randomBytes);\r","    }\r","\r","    public DateTime GetAccessTokenExpiry()\r","    {\r","        var minutes = int.Parse(\r","            _configuration[\"JwtSettings:ExpiryMinutes\"] ?? \"60\");\r","        return DateTime.UtcNow.AddMinutes(minutes);\r","    }\r","\r","    public DateTime GetRefreshTokenExpiry()\r","        => DateTime.UtcNow.AddDays(7);\r","}"]}