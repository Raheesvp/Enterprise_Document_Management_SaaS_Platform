{"lines":["using Gateway.API.Extensions;\r","using Gateway.API.Middleware;\r","using Microsoft.Extensions.Options;\r","using Microsoft.OpenApi.Models;\r","using Serilog;\r","\r","var builder = WebApplication.CreateBuilder(args);\r","\r","// ── Logging ────────────────────────────────────────────────────────────────\r","// Serilog structured logging — every log line has TenantId, RequestId etc.\r","builder.Host.UseSerilog((context, configuration) =>\r","    configuration.ReadFrom.Configuration(context.Configuration));\r","\r","// ── YARP Reverse Proxy ─────────────────────────────────────────────────────\r","// Reads route + cluster config from appsettings.json\r","// Hot-reload supported — change routes without restarting\r","builder.Services.AddReverseProxy()\r","    .LoadFromConfig(builder.Configuration.GetSection(\"ReverseProxy\"));\r","\r","// ── Authentication + Authorization ────────────────────────────────────────\r","// JWT validated HERE at gateway — downstream services trust the headers\r","builder.Services.AddGatewayAuthentication(builder.Configuration);\r","\r","// ── Rate Limiting ──────────────────────────────────────────────────────────\r","builder.Services.AddGatewayRateLimiting();\r","\r","// ── Health Checks ──────────────────────────────────────────────────────────\r","builder.Services.AddHealthChecks();\r","builder.Services.AddEndpointsApiExplorer();\r","\r","\r","builder.Services.AddSwaggerGen(c =>\r","{\r","   \r","\r"," \r","    // 1. Define the Security Scheme (How the lock button works)\r","    c.AddSecurityDefinition(\"Bearer\", new OpenApiSecurityScheme\r","    {\r","        Description = \"JWT Authorization header using the Bearer scheme. Example: \\\"Authorization: Bearer {token}\\\"\",\r","        Name = \"Authorization\",\r","        In = ParameterLocation.Header,\r","        Type = SecuritySchemeType.Http,\r","        Scheme = \"bearer\"\r","    });\r","\r","c.AddSecurityRequirement(new OpenApiSecurityRequirement\r","    {\r","        {\r","            new OpenApiSecurityScheme\r","            {\r","                Reference = new OpenApiReference\r","                {\r","                    Type = ReferenceType.SecurityScheme,\r","                    Id = \"Bearer\"\r","                }\r","            },\r","            new string[] {}\r","        }\r","    });\r","});\r","\r","// ── CORS ───────────────────────────────────────────────────────────────────\r","// Configured once at gateway — downstream services don't need CORS\r","builder.Services.AddCors(options =>\r","{\r","    options.AddPolicy(\"AllowFrontend\", policy =>\r","        policy\r","            .WithOrigins(\r","                \"http://localhost:4200\",\r","                \"http://localhost:3000\",  \r","                \"http://localhost:5173\",\r","                \"http://localhost:5000\"  // Vite dev server\r","                )  // Vite dev server\r","            .AllowAnyHeader()\r","            .AllowAnyMethod()\r","            .AllowCredentials());        \r","});\r","\r","var app = builder.Build();\r","\r","if (app.Environment.IsDevelopment())\r","{\r","    app.UseSwagger();\r","    app.UseSwaggerUI(c =>\r","    {\r","        // Same-origin path via gateway proxy (avoids browser CORS issues)\r","        c.SwaggerEndpoint(\"/identity-swagger/v1/swagger.json\", \"Identity Service API\");\r","\r","        c.SwaggerEndpoint(\"/workflow-swagger/v1/swagger.json\", \"Workflow Service\");\r","\r","        // This shows the Gateway's own (empty) definition\r","        c.SwaggerEndpoint(\"/swagger/v1/swagger.json\", \"Identity Service(via Gateway)\");\r","\r","        c.RoutePrefix = \"swagger\";\r","    });\r","}\r","\r","// ── Middleware Pipeline (ORDER MATTERS) ────────────────────────────────────\r","// 1. Serilog request logging — log every request\r","app.UseSerilogRequestLogging();\r","\r","// 2. CORS — must be before auth\r","app.UseCors(\"AllowFrontend\");\r","\r","// 3. Rate limiting — reject before spending auth resources\r","app.UseRateLimiter();\r","\r","// 4. Authentication — validate JWT\r","app.UseAuthentication();\r","\r","// 5. Authorization — check policies\r","app.UseAuthorization();\r","\r","// 6. Tenant resolution — extract tenant from JWT, add headers\r","app.UseMiddleware<TenantResolutionMiddleware>();\r","\r","// 7. Health check endpoint\r","\r","// 8. YARP — forward to downstream services\r","app.MapHealthChecks(\"/health\");\r","app.MapReverseProxy();\r","\r","app.Run();\r",""]}